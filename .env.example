# =============================================================================
# 환경변수 예제 파일
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
# cp .env.example .env
# =============================================================================

# =============================================================================
# PostgreSQL 데이터베이스
# Docker Compose 사용 시 POSTGRES_HOST=postgres (서비스명)
# 로컬 직접 실행 시 POSTGRES_HOST=localhost
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mystock
POSTGRES_USER=mystock_user
# ⚠️ 반드시 안전한 비밀번호로 변경하세요. 특수문자 포함 12자 이상 권장.
POSTGRES_PASSWORD=your_db_password_here

# =============================================================================
# Redis 캐시
# Docker Compose 사용 시 REDIS_HOST=redis (서비스명)
# 로컬 직접 실행 시 REDIS_HOST=localhost
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# 백엔드 (FastAPI)
# - BACKEND_HOST: 바인딩 주소. 0.0.0.0 은 모든 인터페이스에서 수신
# - BACKEND_PORT: 서버 포트 (Docker 외부: 8000, 내부: 8000)
# - SECRET_KEY: FastAPI 시크릿 키. ⚠️ 운영 환경에서 반드시 랜덤 문자열로 변경
#   생성 방법: python3 -c "import secrets; print(secrets.token_hex(32))"
# - DEBUG: True=개발(상세 에러 노출), False=운영(에러 요약만 노출)
#   ⚠️ 운영 환경에서 반드시 False로 설정
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_secret_key_here_change_in_production
# 개발 환경: True, 운영 환경: False
DEBUG=True

# =============================================================================
# CORS 설정
# - CORS_ORIGINS: 허용할 origin 목록 (콤마 구분)
#   개발: * (전체 허용)
#   운영: https://yourdomain.com,https://www.yourdomain.com
# =============================================================================
CORS_ORIGINS=*

# =============================================================================
# JWT 설정
# - JWT_SECRET: JWT 서명 키. ⚠️ 운영 환경에서 반드시 랜덤 문자열로 변경
#   생성 방법: openssl rand -hex 32
# =============================================================================
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# 초기 관리자 계정 이메일 (DB 직접 주입 시 사용)
ADMIN_EMAIL=admin@mystock.bot

# =============================================================================
# 프론트엔드 (Next.js)
# NEXT_PUBLIC_ 접두사가 붙은 변수는 브라우저에 노출됩니다
# - NEXT_PUBLIC_API_URL: 프론트엔드에서 백엔드 API 호출 시 사용할 기본 URL
#   Docker Compose 사용 시: http://localhost:8000 (호스트에서 접근)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# KIS API 키 및 Telegram 설정은 앱 실행 후 관리자 페이지(설정 > 연동)에서 DB에 직접 입력합니다.
# 이 파일에 KIS/Telegram 관련 환경변수를 추가하지 마세요.
# =============================================================================
