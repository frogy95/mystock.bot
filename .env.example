# =============================================================================
# 환경변수 예제 파일
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
# cp .env.example .env
# =============================================================================

# =============================================================================
# 한국투자증권 (KIS) API
# KIS Developers (https://apiportal.koreainvestment.com) 에서 발급
# - KIS_APP_KEY: 앱 관리 → 앱 생성 후 발급되는 App Key (영문/숫자 혼합 문자열)
# - KIS_APP_SECRET: 앱 생성 후 발급되는 App Secret (영문/숫자 혼합 긴 문자열)
# - KIS_ACCOUNT_NUMBER: 계좌번호 (형식: XXXXXXXX-XX, 예: 50123456-01)
# - KIS_HTS_ID: HTS(eFriend Plus) 로그인 ID
# - KIS_ENVIRONMENT: vts=모의투자(개발/테스트용), prod=실거래 ⚠️실거래는 실제 자금 거래
# =============================================================================
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NUMBER=your_account_number_here
KIS_HTS_ID=your_hts_id_here
# 환경 설정: vts (모의투자) 또는 prod (실거래)
# ⚠️ 개발/테스트 시 반드시 vts 사용. prod 변경 시 실제 자금이 거래됩니다.
KIS_ENVIRONMENT=vts

# =============================================================================
# 텔레그램 봇
# BotFather (@BotFather) 에서 봇 생성 후 발급
# - TELEGRAM_BOT_TOKEN: BotFather가 발급하는 토큰 (형식: 1234567890:ABCdef...)
# - TELEGRAM_CHAT_ID: 알림을 받을 채팅방 ID (숫자, 음수 가능)
#   확인 방법: 봇에게 메시지 전송 후
#   https://api.telegram.org/bot<TOKEN>/getUpdates 에서 "chat.id" 확인
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# PostgreSQL 데이터베이스
# Docker Compose 사용 시 POSTGRES_HOST=postgres (서비스명)
# 로컬 직접 실행 시 POSTGRES_HOST=localhost
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mystock
POSTGRES_USER=mystock_user
# ⚠️ 반드시 안전한 비밀번호로 변경하세요. 특수문자 포함 12자 이상 권장.
POSTGRES_PASSWORD=your_db_password_here

# =============================================================================
# Redis 캐시
# Docker Compose 사용 시 REDIS_HOST=redis (서비스명)
# 로컬 직접 실행 시 REDIS_HOST=localhost
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# 백엔드 (FastAPI)
# - BACKEND_HOST: 바인딩 주소. 0.0.0.0 은 모든 인터페이스에서 수신
# - BACKEND_PORT: 서버 포트 (Docker 외부: 8000, 내부: 8000)
# - SECRET_KEY: JWT 토큰 서명 키. ⚠️ 운영 환경에서 반드시 랜덤 문자열로 변경
#   생성 방법: python3 -c "import secrets; print(secrets.token_hex(32))"
# - DEBUG: True=개발(상세 에러 노출), False=운영(에러 요약만 노출)
#   ⚠️ 운영 환경에서 반드시 False로 설정
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_secret_key_here_change_in_production
# 개발 환경: True, 운영 환경: False
DEBUG=True

# =============================================================================
# 단일 유저 인증
# - ADMIN_USERNAME: 로그인 사용자명 (기본: admin)
# - ADMIN_PASSWORD: 로그인 비밀번호
#   ⚠️ 반드시 기본값에서 변경하세요. 특수문자 포함 12자 이상 권장.
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# =============================================================================
# 프론트엔드 (Next.js)
# NEXT_PUBLIC_ 접두사가 붙은 변수는 브라우저에 노출됩니다
# - NEXT_PUBLIC_API_URL: 프론트엔드에서 백엔드 API 호출 시 사용할 기본 URL
#   Docker Compose 사용 시: http://localhost:8000 (호스트에서 접근)
#   프론트엔드 컨테이너 내부에서 백엔드 호출 시: http://backend:8000 (서비스명)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
