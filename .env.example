# =============================================================================
# 환경변수 예제 파일
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
# cp .env.example .env
# =============================================================================

# =============================================================================
# 한국투자증권 (KIS) API
# KIS Developers (https://apiportal.koreainvestment.com) 에서 발급
# =============================================================================
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NUMBER=your_account_number_here
# 환경 설정: vts (모의투자) 또는 prod (실거래)
KIS_ENVIRONMENT=vts

# =============================================================================
# 텔레그램 봇
# BotFather (@BotFather) 에서 봇 생성 후 발급
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# PostgreSQL 데이터베이스
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mystock
POSTGRES_USER=mystock_user
POSTGRES_PASSWORD=your_db_password_here

# =============================================================================
# Redis 캐시
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# 백엔드 (FastAPI)
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_secret_key_here_change_in_production
# 개발 환경: True, 운영 환경: False
DEBUG=True

# =============================================================================
# 프론트엔드 (Next.js)
# NEXT_PUBLIC_ 접두사가 붙은 변수는 브라우저에 노출됩니다
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
