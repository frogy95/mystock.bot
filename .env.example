# =============================================================================
# Environment variable template
# Copy this file to .env and fill in the actual values.
# cp .env.example .env
# =============================================================================

# =============================================================================
# PostgreSQL
# Docker Compose: POSTGRES_HOST=postgres (service name)
# Local: POSTGRES_HOST=localhost
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mystock
POSTGRES_USER=mystock_user
# ⚠️ Use a strong password (12+ chars with special characters).
POSTGRES_PASSWORD=your_db_password_here

# =============================================================================
# Redis
# Docker Compose: REDIS_HOST=redis (service name)
# Local: REDIS_HOST=localhost
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Backend (FastAPI)
# - BACKEND_HOST: bind address. 0.0.0.0 listens on all interfaces
# - BACKEND_PORT: server port (Docker external: 8000, internal: 8000)
# - SECRET_KEY: FastAPI secret key. ⚠️ Must be changed in production
#   Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# - DEBUG: True=development (verbose errors), False=production (summary only)
#   ⚠️ Must be False in production
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_secret_key_here_change_in_production
# development: True, production: False
DEBUG=True

# =============================================================================
# CORS
# - CORS_ORIGINS: comma-separated list of allowed origins
#   development: * (allow all)
#   production: https://yourdomain.com,https://www.yourdomain.com
# =============================================================================
CORS_ORIGINS=*

# =============================================================================
# JWT
# - JWT_SECRET: signing key. ⚠️ Must be changed in production
#   Generate: openssl rand -hex 32
# =============================================================================
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# Initial admin account email (used for direct DB injection)
ADMIN_EMAIL=admin@mystock.bot

# =============================================================================
# Frontend (Next.js)
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - NEXT_PUBLIC_API_URL: base URL for backend API calls from the frontend
#   Docker Compose: http://localhost:8000 (accessed from host)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# KIS API keys and Telegram settings are configured via the admin page
# (Settings > Integrations) after the app is running.
# Do NOT add KIS/Telegram env vars to this file.
# =============================================================================
